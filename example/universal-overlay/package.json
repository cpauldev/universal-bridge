{
  "name": "@example/universal-overlay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./overlay.css": "./dist/overlay.css",
    "./overlay": {
      "types": "./dist/overlay/index.d.ts",
      "import": "./dist/overlay/index.js",
      "default": "./dist/overlay/index.js"
    },
    "./dashboard": {
      "types": "./dist/dashboard/index.d.ts",
      "import": "./dist/dashboard/index.js",
      "default": "./dist/dashboard/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:styles": "node ./node_modules/@tailwindcss/cli/dist/index.mjs -i src/overlay/styles/overlay.css -o dist/overlay.css --minify",
    "build": "node ./scripts/build.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "postcss": "^8.5.16",
    "postcss-selector-parser": "^7.1.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "universal-bridge": "file:../..",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sileo": "^0.1.5",
    "tailwind-merge": "^3.6.0"
  }
}
