{
  "name": "universal-bridge",
  "version": "0.4.0",
  "description": "A protocol for exposing and controlling local processes across frameworks and runtimes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "default": "./dist/internal.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./client-runtime": {
      "types": "./dist/client/runtime-context.d.ts",
      "default": "./dist/client/runtime-context.js"
    },
    "./preset": {
      "types": "./dist/preset.d.ts",
      "default": "./dist/preset.js"
    },
    "./vite": {
      "types": "./dist/adapters/shared/plugin.d.ts",
      "default": "./dist/adapters/shared/plugin.js"
    },
    "./next": {
      "types": "./dist/adapters/framework/next.d.ts",
      "default": "./dist/adapters/framework/next.js"
    },
    "./astro": {
      "types": "./dist/adapters/framework/astro.d.ts",
      "default": "./dist/adapters/framework/astro.js"
    },
    "./angular/cli": {
      "types": "./dist/adapters/framework/angular-cli.d.ts",
      "default": "./dist/adapters/framework/angular-cli.js"
    },
    "./nuxt": {
      "types": "./dist/adapters/framework/nuxt.d.ts",
      "default": "./dist/adapters/framework/nuxt.js"
    },
    "./vinext": {
      "types": "./dist/adapters/framework/vinext.d.ts",
      "default": "./dist/adapters/framework/vinext.js"
    },
    "./bun": {
      "types": "./dist/adapters/server/bun.d.ts",
      "default": "./dist/adapters/server/bun.js"
    },
    "./fastify": {
      "types": "./dist/adapters/server/fastify.d.ts",
      "default": "./dist/adapters/server/fastify.js"
    },
    "./hono": {
      "types": "./dist/adapters/server/hono.d.ts",
      "default": "./dist/adapters/server/hono.js"
    },
    "./node": {
      "types": "./dist/adapters/server/node.d.ts",
      "default": "./dist/adapters/server/node.js"
    },
    "./rsbuild": {
      "types": "./dist/adapters/build/rsbuild.d.ts",
      "default": "./dist/adapters/build/rsbuild.js"
    },
    "./rspack": {
      "types": "./dist/adapters/build/rspack.d.ts",
      "default": "./dist/adapters/build/rspack.js"
    },
    "./webpack": {
      "types": "./dist/adapters/build/webpack.d.ts",
      "default": "./dist/adapters/build/webpack.js"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "CHANGELOG.md",
    "INTEGRATION_GUIDE.md",
    "EXAMPLE.md",
    "PROTOCOL.md",
    "ARCHITECTURE.md",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*",
    "example/*",
    "example/shared",
    "example/shared/*"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "bun run clean && bun x tsc -p tsconfig.build.json && node scripts/copy-client-entry-loader.mjs",
    "typecheck": "bun x tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "bun run build && bun run test && bun run typecheck",
    "lint": "bun run lint:eslint && bun run typecheck",
    "lint:eslint": "eslint --config .config/eslint.config.mjs \"src/**/*.{ts,js,mjs}\"",
    "lint:md": "markdownlint-cli2 --config .config/.markdownlint-cli2.jsonc",
    "docs:lint": "bun run lint:md",
    "docs:check": "node scripts/check-doc-sync.mjs",
    "format": "prettier --config .config/.prettierrc --write --ignore-path .config/.prettierignore .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepare": "husky .config/.husky",
    "example": "bun scripts/example/run.ts",
    "example:setup": "bun scripts/example/setup.ts",
    "verify:example": "bun scripts/example/verify.ts"
  },
  "keywords": [
    "devtools",
    "overlay",
    "bridge",
    "vite",
    "tanstack",
    "sveltekit",
    "remix",
    "react-router",
    "bun",
    "fastify",
    "hono",
    "rsbuild",
    "rspack",
    "next",
    "angular",
    "vue",
    "astro",
    "nuxt"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cpauldev/universal-bridge.git"
  },
  "author": "Christian Paul",
  "license": "MIT",
  "dependencies": {
    "execa": "^9.6.1",
    "typescript": "^6.0.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-rsc": "^0.5.27",
    "bun-types": "^1.3.14",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.62.1",
    "vinext": "^1.0.0-beta.0",
    "vite": "^8.1.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --config .config/eslint.config.mjs --fix",
      "prettier --config .config/.prettierrc --write --ignore-path .config/.prettierignore"
    ],
    "*.{json,css,html}": [
      "prettier --config .config/.prettierrc --write --ignore-path .config/.prettierignore"
    ],
    "*.md": [
      "markdownlint-cli2 --config .config/.markdownlint-cli2.jsonc --fix",
      "prettier --config .config/.prettierrc --write --ignore-path .config/.prettierignore"
    ]
  }
}
